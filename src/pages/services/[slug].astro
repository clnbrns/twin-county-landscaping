---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import { SERVICES, SERVICE_BY_SLUG } from '../../data/services';

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = SERVICE_BY_SLUG[slug as string];
const related = service.related.map((r) => SERVICE_BY_SLUG[r]).filter(Boolean);

const title = `${service.name} in Aledo, TX | Twin County Outdoor Services`;
const description = `${service.short} Serving Aledo, Benbrook, Weatherford, Fort Worth, and Western DFW. Free in-person quotes from Twin County Outdoor Services.`;
---
<Base title={title} description={description} path={`/services/${service.slug}`}>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Services', href: '/services' },
    { label: service.name },
  ]} />

  <section class="container-x py-12">
    <h1>{service.name} in Aledo, TX</h1>
    <p class="mt-4 text-lg text-brand-muted max-w-3xl">{service.intro}</p>

    <div class="mt-10 grid lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2 space-y-10">
        <div class="aspect-[16/10] bg-brand-green-tint rounded-lg overflow-hidden">
          <img src="/images/placeholder-hero.svg" alt={`${service.name} project in Aledo, TX`} class="w-full h-full object-cover" />
        </div>

        <div>
          <h2>What's included</h2>
          <ul class="mt-4 space-y-2">
            {service.included.map((item) => (
              <li class="flex gap-3"><span class="text-brand-green-dark font-bold">✓</span><span>{item}</span></li>
            ))}
          </ul>
        </div>

        <div class="bg-brand-green-tint p-6 rounded-lg">
          <h3>Why Lucas</h3>
          <p class="mt-2 text-brand-ink">Every {service.name.toLowerCase()} job starts with an in-person walkthrough and a detailed written proposal. Lucas is on every job — Aledo local, owner-operated, no random crews.</p>
        </div>

        {related.length > 0 && (
          <div>
            <h3>Related services</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {related.map((r) => (
                <a href={`/services/${r.slug}`} class="px-3 py-1 bg-white border border-brand-green-tint rounded-full text-sm hover:border-brand-green-dark no-underline">{r.name}</a>
              ))}
            </div>
          </div>
        )}

        <p class="text-sm text-brand-muted">Serving Aledo, Benbrook, Weatherford, Fort Worth, Brock, and surrounding areas.</p>
      </div>

      <aside class="lg:sticky lg:top-24 self-start">
        <QuoteForm compact />
      </aside>
    </div>
  </section>
  <CTABanner />
</Base>
