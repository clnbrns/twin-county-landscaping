---
import { SITE } from '../data/site';

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  primaryHref?: string;
  primaryLabel?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  image = '/images/placeholder-hero.svg',
  primaryHref = '/contact',
  primaryLabel = 'Request a Free Quote',
} = Astro.props;
---

<section class="relative min-h-[70vh] flex items-center bg-brand-ink text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src={image} alt="" class="w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/20"></div>
  </div>
  <div class="relative container-x py-20 md:py-28 max-w-3xl">
    {eyebrow && <div class="uppercase tracking-wider text-sm text-brand-green-tint mb-3">{eyebrow}</div>}
    <h1 class="text-white">{title}</h1>
    {subtitle && <p class="mt-4 text-lg md:text-xl text-white/90 max-w-2xl">{subtitle}</p>}
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={primaryHref} class="btn-primary no-underline">{primaryLabel}</a>
      <a href={SITE.phoneHref} class="btn bg-white/10 text-white border-2 border-white/40 hover:bg-white/20 no-underline">📞 Call</a>
      <a href={SITE.smsHref} class="btn bg-white/10 text-white border-2 border-white/40 hover:bg-white/20 no-underline">💬 Text</a>
    </div>
    <p class="mt-4 text-sm text-white/80">Call, text, or use the form — whatever's easier.</p>
  </div>
</section>
