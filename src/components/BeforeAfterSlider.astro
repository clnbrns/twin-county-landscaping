---
export interface Props {
  before: string;
  after: string;
  alt?: string;
}
const { before, after, alt = 'Before and after comparison' } = Astro.props;
---
<div class="ba-slider relative w-full aspect-[16/10] overflow-hidden rounded-lg select-none touch-pan-y" style="--ba-pct: 50%;">
  <img src={after} alt={`${alt} — after`} class="absolute inset-0 w-full h-full object-cover" />
  <img src={before} alt={`${alt} — before`} class="ba-before absolute inset-0 w-full h-full object-cover" style="clip-path: inset(0 calc(100% - var(--ba-pct)) 0 0);" />
  <div class="ba-handle absolute top-0 bottom-0 w-1 bg-white shadow-lg pointer-events-none" style="left: var(--ba-pct);"></div>
  <button type="button" aria-label="Drag to compare" class="ba-grip absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-11 h-11 rounded-full bg-white shadow flex items-center justify-center text-brand-green-dark font-bold cursor-ew-resize" style="left: var(--ba-pct);">⇆</button>
  <div class="absolute top-2 left-2 bg-black/60 text-white text-xs px-2 py-1 rounded pointer-events-none">Before</div>
  <div class="absolute top-2 right-2 bg-black/60 text-white text-xs px-2 py-1 rounded pointer-events-none">After</div>
</div>

<script>
  const init = (el: HTMLElement) => {
    let dragging = false;
    const set = (clientX: number) => {
      const rect = el.getBoundingClientRect();
      const pct = Math.max(0, Math.min(100, ((clientX - rect.left) / rect.width) * 100));
      el.style.setProperty('--ba-pct', pct + '%');
    };
    const start = (clientX: number) => { dragging = true; set(clientX); };
    el.addEventListener('mousedown', (e) => start(e.clientX));
    el.addEventListener('touchstart', (e) => start(e.touches[0].clientX), { passive: true });
    window.addEventListener('mousemove', (e) => dragging && set(e.clientX));
    window.addEventListener('touchmove', (e) => dragging && set(e.touches[0].clientX), { passive: true });
    window.addEventListener('mouseup', () => (dragging = false));
    window.addEventListener('touchend', () => (dragging = false));
    window.addEventListener('touchcancel', () => (dragging = false));
  };
  document.querySelectorAll<HTMLElement>('.ba-slider').forEach(init);
</script>
