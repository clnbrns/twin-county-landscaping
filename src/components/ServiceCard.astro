---
export interface Props {
  slug: string;
  name: string;
  short: string;
  image?: string;
}
const { slug, name, short, image = '/images/placeholder-service.svg' } = Astro.props;
---
<a href={`/services/${slug}`} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-brand-green-tint no-underline">
  <div class="aspect-[4/3] overflow-hidden bg-brand-green-tint">
    <img src={image} alt={`${name} in Aledo, TX`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
  </div>
  <div class="p-5">
    <h3 class="text-brand-ink group-hover:text-brand-green-dark">{name}</h3>
    <p class="text-sm text-brand-muted mt-2">{short}</p>
    <span class="inline-block mt-3 text-brand-green-dark font-semibold text-sm">Learn more →</span>
  </div>
</a>
