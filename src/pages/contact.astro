---
import Base from '../layouts/Base.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { SITE } from '../data/site';
import { AREAS } from '../data/areas';
---
<Base
  title={`Request a Free Quote | ${SITE.name} — Aledo, TX`}
  description="Get a free landscape or hardscape quote from Twin County Outdoor Services. Lucas walks your property in person and provides a detailed written proposal within 24 hours."
  path="/contact"
>
  <section class="container-x py-10 md:py-16">
    <div class="max-w-3xl">
      <h1>Get a Free Quote</h1>
      <p class="mt-3 text-lg text-brand-muted">Call, text, or fill out the form — whatever's easiest. Lucas will get back to you within 24 hours.</p>
      <div class="mt-5 grid grid-cols-2 gap-3 max-w-md">
        <a href={SITE.phoneHref} class="btn-primary !py-3 no-underline">📞 Call Lucas</a>
        <a href={SITE.smsHref} class="btn-secondary !py-3 no-underline">💬 Text Lucas</a>
      </div>
      <p class="mt-3 text-sm text-brand-muted"><a href={SITE.phoneHref} class="font-semibold">{SITE.phone}</a></p>
    </div>

    <div class="mt-10 grid lg:grid-cols-[1fr_360px] gap-10 items-start">
      <div>
        <QuoteForm />
      </div>

      <aside class="space-y-8">
        <div>
          <h2 class="text-2xl">What happens next?</h2>
          <ol class="mt-4 space-y-4">
            {[
              'Lucas calls or texts within 24 hours.',
              'He visits in person to walk your property.',
              'You receive a detailed written proposal with scope and pricing.',
            ].map((step, i) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-green-dark text-white font-bold flex items-center justify-center">{i + 1}</span>
                <span class="text-brand-ink">{step}</span>
              </li>
            ))}
          </ol>
        </div>

        <div>
          <h2 class="text-2xl">Where we work</h2>
          <ul class="mt-3 grid grid-cols-2 gap-2 text-sm">
            {AREAS.map((a) => <li><a href={`/areas/${a.slug}`}>{a.city}, {a.state}</a></li>)}
          </ul>
        </div>
      </aside>
    </div>
  </section>
</Base>
