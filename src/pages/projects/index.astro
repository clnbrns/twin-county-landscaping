---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { PROJECTS } from '../../data/projects';
---
<Base
  title="Our Projects | Twin County Outdoor Services — Aledo, TX"
  description="Recent landscape, retaining wall, hardscape, and drainage projects from Twin County Outdoor Services across Aledo, Weatherford, Fort Worth, and Western DFW."
  path="/projects"
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Projects' }]} />
  <section class="container-x py-12">
    <h1>Our Work</h1>
    <p class="mt-3 text-lg text-brand-muted max-w-2xl">A selection of recent projects from across Western DFW. More added as jobs wrap.</p>
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {PROJECTS.map((p) => <ProjectCard slug={p.slug} title={p.title} city={p.city} summary={p.summary} image={p.hero} />)}
    </div>
  </section>
  <CTABanner />
</Base>
