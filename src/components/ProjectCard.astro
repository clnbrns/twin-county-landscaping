---
export interface Props {
  slug: string;
  title: string;
  city: string;
  summary: string;
  image: string;
}
const { slug, title, city, summary, image } = Astro.props;
---
<a href={`/projects/${slug}`} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-brand-green-tint no-underline">
  <div class="aspect-[4/3] overflow-hidden bg-brand-green-tint">
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
  </div>
  <div class="p-5">
    <div class="text-xs uppercase tracking-wide text-brand-green-dark font-semibold">{city}</div>
    <h3 class="mt-1 text-brand-ink group-hover:text-brand-green-dark">{title}</h3>
    <p class="text-sm text-brand-muted mt-2">{summary}</p>
  </div>
</a>
