---
export interface Props {
  items: { label: string; href?: string }[];
}
const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="container-x pt-6 text-sm text-brand-muted">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {item.href ? <a href={item.href} class="hover:text-brand-green-dark">{item.label}</a> : <span class="text-brand-ink">{item.label}</span>}
        {i < items.length - 1 && <span class="text-brand-muted/50">/</span>}
      </li>
    ))}
  </ol>
</nav>
