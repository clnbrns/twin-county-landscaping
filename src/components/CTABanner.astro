---
import { SITE } from '../data/site';
export interface Props { title?: string; subtitle?: string; }
const {
  title = 'Ready to transform your yard?',
  subtitle = 'Free quotes. In-person walkthroughs. Detailed written proposals.',
} = Astro.props;
---
<section class="bg-brand-green-dark text-white">
  <div class="container-x py-12 md:py-16 flex flex-col md:flex-row items-center justify-between gap-6">
    <div>
      <h2 class="text-white">{title}</h2>
      <p class="mt-2 text-white/90">{subtitle}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="btn bg-white text-brand-green-dark hover:bg-brand-green-tint no-underline">Request a Free Quote</a>
      <a href={SITE.phoneHref} class="btn border-2 border-white text-white hover:bg-white/10 no-underline">📞 {SITE.phone}</a>
    </div>
  </div>
</section>
